---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="A quiet private launcher for self-hosted services." />
    <meta name="theme-color" content="#fdfbf7" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Latch</title>
    <link rel="icon" href="/icon.svg" type="image/svg+xml" />
    <link rel="manifest" href="/manifest.webmanifest" />
  </head>
  <body>
    <latch-app services-src="/services.json"></latch-app>
    <noscript>Latch needs JavaScript to load your service list.</noscript>
    <script>
      import "../components/latch-app.ts";
    </script>
    <script is:inline>
      if (
        "serviceWorker" in navigator &&
        (location.protocol === "https:" || location.hostname === "localhost")
      ) {
        window.addEventListener("load", () => {
          navigator.serviceWorker.register("/sw.js").catch(() => undefined);
        });
      }
    </script>
  </body>
</html>
