{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "exactOptionalPropertyTypes": true,
    "moduleResolution": "bundler",
    "noUncheckedIndexedAccess": true,
    "types": ["node", "vitest/globals", "@cloudflare/workers-types"]
  },
  "include": [
    "src",
    "scripts",
    "tests",
    "astro.config.mjs",
    "eslint.config.mjs",
    "vitest.config.ts"
  ]
}
