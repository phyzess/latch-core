# Cloudflare Access is required outside local development.
# TEAM_DOMAIN may be the base Access URL or the full /cdn-cgi/access/certs URL.
POLICY_AUD=your-access-policy-audience-tag
TEAM_DOMAIN=https://your-team.cloudflareaccess.com

# Comma-separated Access user emails that can edit links in /settings.
LATCH_ADMIN_EMAILS=admin@example.com
